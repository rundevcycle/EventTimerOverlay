<Window x:Class="EventTimerOverlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Opacity="0"
        ResizeMode="CanResizeWithGrip"
        MinHeight="50"
        MinWidth="75">

    <Grid>
        <!-- Background drag area -->
        <Border Background="#22000000"
            MouseLeftButtonDown="DragArea_MouseLeftButtonDown">

            <Grid>

                <!-- Horizontal bar -->
                <Border x:Name="HorizontalBar"
                    Height="Auto"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Left"/>

                <!-- Vertical bar -->
                <Border x:Name="VerticalBar"
                    Width="Auto"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    Visibility="Collapsed"/>

                <!-- Timer text -->
                <Viewbox Stretch="Uniform"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="10">

                    <TextBlock x:Name="TimerText"
                       Foreground="White"
                       FontWeight="Bold">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="3" ShadowDepth="0" Color="Black"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </Viewbox>
            </Grid>
        </Border>
    </Grid>
</Window>